{
  "name": "kilic-ve-kantar",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=apps/server\" \"npm run dev --workspace=apps/client\"",
    "build": "npm run build --workspace=packages/shared && npm run build --workspace=apps/client && npm run build --workspace=apps/server",
    "start": "npm run start --workspace=apps/server",
    "db:migrate": "npm run db:migrate --workspace=apps/server",
    "db:migrate:prod": "npm run db:migrate:prod --workspace=apps/server",
    "db:generate": "npm run db:generate --workspace=apps/server",
    "db:studio": "npm run db:studio --workspace=apps/server",
    "db:seed": "npm run db:seed --workspace=apps/server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  }
}