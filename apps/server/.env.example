NODE_ENV=development
PORT=3001

# PostgreSQL — Railway sets this automatically
DATABASE_URL="postgresql://postgres:password@localhost:5432/kilic_ve_kantar"

# Redis — Railway sets this automatically
REDIS_URL="redis://localhost:6379"

# JWT — generate strong secrets for production!
# Example: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="super-secret-jwt-key-change-in-production-min-32-chars"
JWT_REFRESH_SECRET="super-secret-refresh-key-change-in-production-min-32"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# CORS — set to your Railway domain in production (e.g. https://kilic-ve-kantar.up.railway.app)
# In production, leave blank since frontend is served from the same origin
CLIENT_URL="http://localhost:5173"

# Admin setup key — change this
ADMIN_SETUP_KEY="change-this-in-production"
